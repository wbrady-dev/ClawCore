{
  "name": "threadclaw-memory",
  "version": "0.3.0",
  "description": "ThreadClaw Memory Engine — DAG-based lossless conversation memory with incremental compaction (based on lossless-claw by Martian Engineering)",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "Wesley Brady",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "context-management",
    "llm",
    "summarization",
    "conversation-memory",
    "dag"
  ],
  "scripts": {
    "changeset": "changeset",
    "release:verify": "npm test && npm pack --dry-run",
    "test": "vitest run --dir test",
    "version-packages": "changeset version"
  },
  "files": [
    "index.ts",
    "src/**/*.ts",
    "openclaw.plugin.json",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.53.0",
    "@mariozechner/pi-ai": "^0.53.0",
    "@sinclair/typebox": "0.34.48"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@mariozechner/pi-coding-agent": "^0.53.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/threadclaw.git",
    "directory": "memory-engine"
  },
  "homepage": "https://github.com/openclaw/threadclaw#memory-engine",
  "bugs": {
    "url": "https://github.com/openclaw/threadclaw/issues"
  }
}
