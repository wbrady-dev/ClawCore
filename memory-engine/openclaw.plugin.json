{
  "id": "threadclaw-memory",
  "uiHints": {
    "contextThreshold": {
      "label": "Context Threshold",
      "help": "Fraction of context window that triggers compaction (0.0–1.0)"
    },
    "incrementalMaxDepth": {
      "label": "Incremental Max Depth",
      "help": "How deep incremental compaction goes (0 = leaf only, -1 = unlimited)"
    },
    "freshTailCount": {
      "label": "Fresh Tail Count",
      "help": "Number of recent messages protected from compaction"
    },
    "dbPath": {
      "label": "Database Path",
      "help": "Path to ThreadClaw Memory SQLite database (default: ~/.threadclaw/data/memory.db)"
    },
    "summaryModel": {
      "label": "Summary Model",
      "help": "Model override for ThreadClaw Memory summarization (e.g., 'gpt-5.4' to reuse the session provider, or 'openai-resp/gpt-5.4' for a full cross-provider ref)"
    },
    "summaryProvider": {
      "label": "Summary Provider",
      "help": "Provider override used only when summaryModel is a bare model name (e.g., 'openai-resp')"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "contextThreshold": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "incrementalMaxDepth": {
        "type": "integer",
        "minimum": -1
      },
      "freshTailCount": {
        "type": "integer",
        "minimum": 1
      },
      "leafMinFanout": {
        "type": "integer",
        "minimum": 2
      },
      "condensedMinFanout": {
        "type": "integer",
        "minimum": 2
      },
      "condensedMinFanoutHard": {
        "type": "integer",
        "minimum": 2
      },
      "dbPath": {
        "type": "string"
      },
      "largeFileThresholdTokens": {
        "type": "integer",
        "minimum": 1000
      },
      "summaryModel": {
        "type": "string"
      },
      "summaryProvider": {
        "type": "string"
      },
      "relationsEnabled": {
        "type": "boolean"
      },
      "relationsGraphDbPath": {
        "type": "string"
      },
      "relationsAwarenessEnabled": {
        "type": "boolean"
      },
      "relationsClaimExtractionEnabled": {
        "type": "boolean"
      },
      "relationsAttemptTrackingEnabled": {
        "type": "boolean"
      },
      "relationsDeepExtractionEnabled": {
        "type": "boolean"
      },
      "relationsDeepExtractionModel": {
        "type": "string"
      },
      "relationsDeepExtractionProvider": {
        "type": "string"
      },
      "relationsContextTier": {
        "type": "string"
      },
      "relationsMinMentions": {
        "type": "integer"
      },
      "relationsStaleDays": {
        "type": "integer"
      },
      "relationsAwarenessMaxNotes": {
        "type": "integer"
      },
      "relationsAwarenessMaxTokens": {
        "type": "integer"
      },
      "relationsAwarenessDocSurfacing": {
        "type": "boolean"
      },
      "relationsUserClaimExtractionEnabled": {
        "type": "boolean"
      },
      "relationsDecayIntervalDays": {
        "type": "integer"
      }
    }
  }
}
